# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Opcional: si se define, deploy-commands.ts registra los comandos solo en este servidor
# (registro instantáneo, ideal para desarrollo). Si se deja vacío, registra global (tarda ~1h en propagar).
DISCORD_GUILD_ID=

# Lavalink (debe coincidir con lavalink/application.yml)
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Spotify (https://developer.spotify.com/dashboard) - usado por el plugin LavaSrc
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Opcional pero necesario para reproducir PLAYLISTS de Spotify (Spotify bloquea ese endpoint para
# credenciales de solo-app). Es la cookie "sp_dc" de una cuenta de Spotify logueada en el navegador.
# Ver README para instrucciones de cómo obtenerla. Trátala como una contraseña.
SPOTIFY_SP_DC=

# Apple Music (opcional - LavaSrc puede generar el token él mismo a partir de una private key de MusicKit,
# https://developer.apple.com/musickit/ -> coloca el archivo .p8 en lavalink/AuthKey.p8)
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
