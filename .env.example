# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Opcional: si se define, deploy-commands.ts registra los comandos solo en este servidor
# (registro instantáneo, ideal para desarrollo). Si se deja vacío, registra global (tarda ~1h en propagar).
DISCORD_GUILD_ID=

# Lavalink (debe coincidir con lavalink/application.yml)
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Spotify (https://developer.spotify.com/dashboard) - usado por el plugin LavaSrc
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Opcional - cookie "sp_dc" de una cuenta de Spotify logueada. Solo la usa LavaSrc para la API de
# letras (lyrics, no implementada en este bot todavía) - NO habilita playlists (ver README). Trátala
# como una contraseña.
SPOTIFY_SP_DC=

# Apple Music - token JWT público del reproductor web de music.apple.com (no requiere cuenta).
# Cómo obtenerlo: abre music.apple.com, DevTools (F12) -> pestaña Network -> reproduce algo o
# navega -> filtra por "amp-api" -> copia el valor del header "authorization" de cualquier
# request (sin el prefijo "Bearer "). Es el JWT cuyo header dice "kid":"WebPlayKid".
# Apple los emite con ~1 mes de validez; si los links de Apple Music dejan de resolver, re-extráelo.
APPLE_MUSIC_MEDIA_API_TOKEN=
